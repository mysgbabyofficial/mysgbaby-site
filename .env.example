# MySGBaby — environment variables (copy to .env.local; never commit real secrets)

# Public site URL
NEXT_PUBLIC_SITE_URL=https://mysgbaby.com

# Analytics (PDPA: only load after consent)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mysgbaby.com
# NEXT_PUBLIC_GA4_ID=

# Affiliate tags (Phase 2+; disclosure required — see docs/RISK-AND-FEASIBILITY.md §1d)
# SHOPEE_AFFILIATE_ID=
# LAZADA_AFFILIATE_ID=
# AMAZON_ASSOCIATES_SG_TAG=

# Data automation (Phase 5). Store real values in GitHub Secrets, never here.
# TRANSLATION_API_KEY=
# IMAGE_GEN_API_KEY=
# GH_ISSUE_TOKEN=            # opens review-queue issues instead of auto-publishing
